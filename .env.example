# ── ShieldTech frontend env (public — safe in the client bundle) ──
# For local dev: copy to `.env` at the repo root. For the live GitHub Pages
# build: add these two as GitHub repository SECRETS (Settings → Secrets and
# variables → Actions), which the deploy workflow injects at build time.
# For Vercel: add them in each project's Environment Variables.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...your-anon-public-key...

# Optional — production app URLs (used for cross-app links). Defaults are fine.
# VITE_PORTAL_APP_URL=https://portal.shieldtechsolutions.com
# VITE_TECH_APP_URL=https://tech.shieldtechsolutions.com
# VITE_CUSTOMER_APP_URL=https://customer.shieldtechsolutions.com

# ── NEVER put these in frontend env — they are Supabase Edge Function SECRETS ──
# Set them in the Supabase dashboard (Edge Functions → Secrets), not here:
#   SUPABASE_SERVICE_ROLE_KEY, OPENAI_API_KEY, RESEND_API_KEY,
#   INVITE_FROM_EMAIL, CRON_SECRET, SAM_GOV_API_KEY, RIPPLING_API_TOKEN
