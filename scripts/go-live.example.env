# ── Fill these 6 values, save as scripts/go-live.env, then run: bash scripts/go-live.sh ──
# (go-live.env is gitignored — your keys never get committed.)

# From Supabase → Project Settings → API
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxx          # the xxxx in https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # "service_role" key (secret)

# From platform.openai.com/api-keys (add billing first)
OPENAI_API_KEY=sk-...

# From resend.com/api-keys (after adding your domain)
RESEND_API_KEY=re_...

# The "from" line for outgoing mail
INVITE_FROM_EMAIL=ShieldTech <no-reply@shieldtechsolutions.com>

# Any long random string — one was generated for you; paste it here
CRON_SECRET=184fb537ee92895f6a45fb2274be402884deca97c893a13a42bfe3ae4f500707
