{
  "name": "shieldtech-platform",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/portal",
    "build": "npm run build -w apps/portal && npm run build -w apps/tech && npm run build -w apps/customer",
    "build:portal": "npm run build -w apps/portal",
    "build:tech": "npm run build -w apps/tech",
    "build:customer": "npm run build -w apps/customer",
    "preview": "npm run preview -w apps/portal"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/montserrat": "^5.2.5",
    "@simplewebauthn/browser": "^13.3.0",
    "@supabase/supabase-js": "^2.49.0",
    "@tensorflow-models/coco-ssd": "^2.2.2",
    "@tensorflow-models/deeplab": "^0.2.2",
    "@tensorflow/tfjs": "^3.21.0",
    "leaflet": "^1.9.4",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.1",
    "vite": "^6.0.0"
  }
}
